# GEMINI_API_KEY: Only needed if you add Gemini AI API calls. Not used by the current bingo app.
GEMINI_API_KEY=""

# APP_URL: Not used by the current bingo app. Leave empty unless you add features that need self-referential links.
APP_URL=""

# DATABASE_FILE: Absolute path to the SQLite file. On Render, point this to your persistent disk mount.
# Example when the disk is mounted at /opt/render/project/.data
DATABASE_FILE="/opt/render/project/.data/bingo.db"
